{
  "requestHandler":{
    "/suggest":{
      "name":"/suggest",
      "class":"solr.SearchHandler",
      "defaults":{
        "suggest":"true",
        "suggest.count":"10",
        "suggest.dictionary":"default"},
      "components":["suggest"]},
    "/select":{
      "name":"/select",
      "class":"solr.SearchHandler",
      "defaults":{"wt":"json"},
      "last-components":["spellcheck"]}},
  "userProps":{"update.autoCreateFields":"false"},
  "searchComponent":{"suggest":{
      "name":"suggest",
      "class":"solr.SuggestComponent",
      "suggester":{
        "name":"default",
        "lookupImpl":"AnalyzingInfixLookupFactory",
        "dictionaryImpl":"DocumentDictionaryFactory",
        "field":"headline",
        "weightField":"stars",
        "suggestAnalyzerFieldType":"text_general",
        "buildOnStartup":"true",
        "buildOnCommit":"true"}}}}